# Pharos environment configuration.
# Copy to .env for local development. All values below match docker-compose.yml.

# --- Deployment identity ---
PHAROS_ENV=local            # local | dev | staging | prod

# --- Postgres (operational state) ---
PHAROS_PG_URL=postgres://pharos:pharos_local_dev@localhost:5433/pharos

# --- Redis (verdict cache) ---
PHAROS_REDIS_URL=redis://localhost:6380

# --- S3-compatible WORM evidence store ---
PHAROS_S3_ENDPOINT=http://localhost:9010
PHAROS_S3_REGION=us-east-1
PHAROS_S3_BUCKET=pharos-evidence
PHAROS_S3_ACCESS_KEY=pharos
PHAROS_S3_SECRET_KEY=pharos_local_dev
PHAROS_S3_FORCE_PATH_STYLE=true
# Object Lock retention (days) applied to every sealed evidence object.
PHAROS_S3_WORM_RETENTION_DAYS=3650

# --- Signing keys (KMS) ---
# local-kms  -> simulated KMS backed by an encrypted local keystore (dev/test)
# aws-kms    -> AWS KMS (set PHAROS_KMS_KEY_ARN per tenant in prod)
PHAROS_KMS_PROVIDER=local-kms
PHAROS_KMS_KEYSTORE_DIR=.pharos-keystore

# --- API service ---
PHAROS_API_PORT=4000
PHAROS_VERDICT_DEADLINE_MS=800
# Comma-separated allowed CORS origins. Empty = deny cross-origin browser calls.
PHAROS_ALLOWED_ORIGINS=http://localhost:3000
# Per-principal (tenant+subject) request budget per minute.
PHAROS_RATE_LIMIT_PER_MIN=600

# --- Identity & access (Sprint 1: Gatehouse) ---
# Platform-operator bootstrap token for tenant provisioning (POST /v1/admin/tenants).
PHAROS_ADMIN_TOKEN=local-admin-please-change
# Trusted OIDC issuers as a JSON array (Okta, Entra, ...). Empty disables SSO bearer auth.
# Example: [{"issuer":"https://acme.okta.com","audience":"pharos","jwksUri":"https://acme.okta.com/oauth2/v1/keys","claims":{"tenant":"pharos_tenant","roles":"pharos_roles"}}]
PHAROS_OIDC_ISSUERS=[]
