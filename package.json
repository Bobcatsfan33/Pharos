{
  "name": "pharos",
  "version": "0.1.0",
  "private": true,
  "description": "Pharos — the trust control plane for enterprise AI agents. Pharos decides. Pharos proves.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./services/* build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v",
    "infra:logs": "docker compose logs -f",
    "demo:durability": "tsx --env-file=.env scripts/demo-durability.ts",
    "verify:external": "tsx --env-file=.env scripts/external-verify.ts",
    "api:dev": "tsx --env-file=.env services/api/src/server.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "jose": "^5.9.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
