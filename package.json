{
  "name": "pharos",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Pharos — the trust control plane for enterprise AI agents. Pharos decides. Pharos proves.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./services/* build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v",
    "infra:logs": "docker compose logs -f",
    "demo:durability": "tsx --env-file=.env scripts/demo-durability.ts",
    "verify:external": "tsx --env-file=.env scripts/external-verify.ts",
    "verify:bundle": "tsx scripts/external-verify.ts --bundle",
    "api:dev": "tsx --env-file=.env services/api/src/server.ts",
    "judges:train": "tsx scripts/train-judges.ts",
    "bench:latency": "tsx --env-file=.env scripts/bench-latency.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "fastify": "^5.10.0",
    "globals": "^15.15.0",
    "jose": "^5.9.6",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^2.1.8"
  }
}
