# Pharos customer-hosted secrets. Copy to .env.prod and set EVERY value (no defaults).
PHAROS_PG_USER=pharos
PHAROS_PG_PASSWORD=change-me-strong
PHAROS_PG_DB=pharos
PHAROS_REDIS_PASSWORD=change-me-strong
PHAROS_S3_ACCESS_KEY=change-me
PHAROS_S3_SECRET_KEY=change-me-strong
PHAROS_S3_REGION=us-east-1
PHAROS_S3_BUCKET=pharos-evidence
PHAROS_KMS_PROVIDER=local-kms
PHAROS_ADMIN_TOKEN=change-me-bootstrap-token
PHAROS_API_PORT=4000
PHAROS_ALLOWED_ORIGINS=https://console.your-domain.example
PHAROS_IMAGE=pharos/api:latest
